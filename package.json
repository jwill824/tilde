{
  "name": "tilde",
  "version": "0.1.0",
  "description": "Interactive CLI to bootstrap a complete macOS developer environment",
  "type": "module",
  "bin": {
    "tilde": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "bootstrap.sh"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:contract": "vitest run --config vitest.contract.config.ts",
    "lint": "eslint src"
  },
  "keywords": [
    "cli",
    "macos",
    "developer",
    "dotfiles",
    "bootstrap"
  ],
  "license": "MIT",
  "dependencies": {
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "zod": "^4.3.6",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "ink-testing-library": "^4.0.0",
    "semantic-release": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "5.4",
    "vitest": "^4.1.2"
  }
}
